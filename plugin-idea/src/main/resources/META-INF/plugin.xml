<idea-plugin>
    <id>org.openprojectx.cqa</id>
    <name>Code Quality Assistant</name>
    <vendor>DTC ADA</vendor>
    <description>Code Quality Assistant driven by AI, empowering TDD, first classs support for contract based testing </description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <editorNotificationProvider implementation="org.openprojectx.ai.plugin.OpenApiEditorNotificationProvider"/>
        <projectConfigurable instance="org.openprojectx.ai.plugin.AiTestSettingsConfigurable"/>
        <projectService serviceImplementation="org.openprojectx.ai.plugin.SonarQubeProjectSettings"/>

        <toolWindow id="AI Context Box"
                    anchor="right"
                    factoryClass="org.openprojectx.ai.plugin.ContextBoxToolWindowFactory"
                    icon="/icons/blue-bulb.svg"
                    canCloseContents="false"
                    stripeTitle="AI Context Box"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <notificationGroup
                id="OpenProjectX Notifications"
                displayType="BALLOON"
                isLogByDefault="true"/>
    </extensions>

    <actions>
        <group
                id="org.openprojectx.ai.plugin.GenerateCommitMessagePromptMenuAction"
                class="org.openprojectx.ai.plugin.GenerateCommitMessagePromptMenuAction"
                text="Generate Commit Message (Choose Prompt)"
                description="Choose a configured prompt to generate commit message">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </group>
        <action
                id="org.openprojectx.ai.plugin.PushAndCreatePrAction"
                class="org.openprojectx.ai.plugin.PushAndCreatePrAction"
                text="Push and Create PR"
                description="Push current branch and create a pull request with AI summary comment">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
        <group
                id="org.openprojectx.ai.plugin.BranchDiffPromptMenuAction"
                class="org.openprojectx.ai.plugin.BranchDiffPromptMenuAction"
                text="Analyze Branch Diff"
                description="Choose a configured prompt to analyze branch diff">
            <add-to-group group-id="Vcs.Log.ContextMenu" anchor="first"/>
        </group>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeVcsLogInternalToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeVcsLogInternalToolbarAction"
                text="Summarize [Probe Vcs.Log.Toolbar.Internal]"
                description="Summarize [Probe Vcs.Log.Toolbar.Internal]">
            <add-to-group group-id="Vcs.Log.Toolbar.Internal" anchor="last"/>
        </action>

        <action
                id="org.openprojectx.ai.plugin.SonarQubeCoverageAction"
                class="org.openprojectx.ai.plugin.SonarQubeCoverageAction"
                text="SonarQube Coverage"
                description="Show SonarQube test coverage and generate missing tests with AI">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.CodeGenerateReviewAction"
                class="org.openprojectx.ai.plugin.CodeGenerateReviewAction"
                text="Code Generate &amp; Review"
                description="Send selected code with a selected prompt to LLM and show result in AI Context Box">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
