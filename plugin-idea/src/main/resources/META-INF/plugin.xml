<idea-plugin>
    <id>org.openprojectx.aitestgen</id>
    <name>AI Test Generator</name>
    <vendor>OpenProjectX</vendor>
    <description>AI Test Generator driven by AI, empowering TDD, first classs support for contract based testing </description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <editorNotificationProvider implementation="org.openprojectx.ai.plugin.OpenApiEditorNotificationProvider"/>
        <projectConfigurable instance="org.openprojectx.ai.plugin.AiTestSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <notificationGroup
                id="OpenProjectX Notifications"
                displayType="BALLOON"
                isLogByDefault="true"/>
    </extensions>

    <actions>
        <action
                id="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                class="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                text="Generate Commit Message"
                description="Generate commit message from current git diff using AI">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
