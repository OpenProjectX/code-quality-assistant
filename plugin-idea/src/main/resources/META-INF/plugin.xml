<idea-plugin>
    <id>org.openprojectx.aitestgen</id>
    <name>AI Test Generator</name>
    <vendor>OpenProjectX</vendor>
    <description>AI Test Generator driven by AI, empowering TDD, first classs support for contract based testing </description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <editorNotificationProvider implementation="org.openprojectx.ai.plugin.OpenApiEditorNotificationProvider"/>
        <projectConfigurable instance="org.openprojectx.ai.plugin.AiTestSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <notificationGroup
                id="OpenProjectX Notifications"
                displayType="BALLOON"
                isLogByDefault="true"/>
    </extensions>

    <actions>
        <action
                id="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                class="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                text="Generate Commit Message"
                description="Generate commit message from current git diff using AI">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchDiffViewerAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchDiffViewerAction"
                text="Summarize Branch Differences (Diff Viewer)"
                description="Summarize Branch Differences (Diff Viewer)">
            <add-to-group group-id="Diff.ViewerToolbar" anchor="after" relative-to-action="Diff.ShowSettingsPopup"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchVcsDiffAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchVcsDiffAction"
                text="Summarize Branch Differences (VCS Diff)"
                description="Summarize Branch Differences (VCS Diff)">
            <add-to-group group-id="Vcs.Diff.Toolbar" anchor="after" relative-to-action="Diff.ShowSettingsPopup"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchChangesViewAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchChangesViewAction"
                text="Summarize Branch Differences (Changes View)"
                description="Summarize Branch Differences (Changes View)">
            <add-to-group group-id="ChangesViewToolbar" anchor="after" relative-to-action="ChangesView.ViewOptions"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchLogToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchLogToolbarAction"
                text="Summarize Branch Differences (VCS Log)"
                description="Summarize Branch Differences (VCS Log)">
            <add-to-group group-id="Vcs.Log.Toolbar.Internal" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchVcsLogToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchVcsLogToolbarAction"
                text="Summarize Branch Differences (VCS Log Toolbar)"
                description="Summarize Branch Differences (VCS Log Toolbar)">
            <add-to-group group-id="Vcs.Log.Toolbar" anchor="after" relative-to-action="Vcs.Log.Refresh"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchDiffToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchDiffToolbarAction"
                text="Summarize Branch Differences (Diff Toolbar)"
                description="Summarize Branch Differences (Diff Toolbar)">
            <add-to-group group-id="Diff.Toolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchDiffEditorToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchDiffEditorToolbarAction"
                text="Summarize Branch Differences (Diff Editor Toolbar)"
                description="Summarize Branch Differences (Diff Editor Toolbar)">
            <add-to-group group-id="Diff.EditorToolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchFileHistoryToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchFileHistoryToolbarAction"
                text="Summarize Branch Differences (File History Toolbar)"
                description="Summarize Branch Differences (File History Toolbar)">
            <add-to-group group-id="Vcs.FileHistory.Toolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeBranchComparePopupToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeBranchComparePopupToolbarAction"
                text="Summarize Branch Differences (Compare Popup)"
                description="Summarize Branch Differences (Compare Popup)">
            <add-to-group group-id="Git.Branches.ToolBar" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
